{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PrepNet",
  "version": "0.1.0",
  "identifier": "network.prepper.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Prepper Network",
        "width": 390,
        "height": 844,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:*; connect-src 'self' ws://localhost:* http://localhost:* wss://gun-relay.prepper.network https://gun-relay.prepper.network; script-src 'self' http://localhost:* 'unsafe-eval' 'unsafe-inline'; style-src 'self' http://localhost:* 'unsafe-inline'; media-src 'self' blob: mediastream:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
